# Obiente Translate Environment Map
#
# This file documents which environment variables belong to which service.
# Do not put every variable into every service.


# =========================
# Service: translate frontend
# =========================
#
# These are Vite build-time variables for the Vue app at translate.obiente.
# They are baked into the frontend bundle when you build/deploy the site.

VITE_WHISPER_ENDPOINT=https://whisper.obiente.cloud/transcribe
VITE_WHISPER_STREAMING_ENDPOINT=wss://whisper.obiente.cloud/ws/transcribe
VITE_MPEGV_SERVE_URL=https://serve.mpeg-v.com
VITE_LIBRE_TRANSLATE_BASE=https://libretranslate.obiente.cloud
VITE_LIBRE_TRANSLATE_ALTERNATIVES=3


# =========================
# Service: gowhisper
# =========================
#
# These are runtime variables for the Go Whisper transcription server.
# Set them on the container that runs gowhisper.

WHISPER_GO_ADDR=:8080
LOG_LEVEL=info

# CPU live-caption tuning.
# Ryzen 7600-ish starting point:
# - keep pool at 1 to avoid multiple Whisper jobs fighting over CPU
# - use tighter windows for lower latency
WHISPER_ENGINE_POOL_SIZE=1
WHISPER_THREADS=6
WHISPER_LIVE_WINDOW_MS=1000
WHISPER_MAX_WINDOW_MS=3000
WHISPER_REALTIME_MAX_LAG_MS=6000

# Multilingual Whisper model selection.
# Example values: base, small, small-q5_1, medium-q5_0, large-v3-turbo-q5_0
WHISPER_MODEL_NAME=small-q5_1

# If the file at WHISPER_MODEL_PATH is missing:
# - auto: download it at startup
# - true: always allow download when missing
# - false: fail startup instead
WHISPER_MODEL_DOWNLOAD=auto

# Optional override if you want a custom path or mounted filename.
WHISPER_MODEL_PATH=/models/ggml-small-q5_1.bin

# Optional custom model download base.
WHISPER_MODEL_BASE_URL=https://huggingface.co/ggerganov/whisper.cpp/resolve/main

# Server-side translation from gowhisper to LibreTranslate.
TRANSLATION_BASE_URL=https://libretranslate.obiente.cloud
WHISPER_SERVER_TRANSLATIONS=true
WHISPER_SERVER_TRANSLATE_PARTIALS=true
TRANSLATION_TIMEOUT=8

# Optional: write received utterance audio windows to WAV files for debugging.
# Helpful when comparing what the bot sent vs what gowhisper actually heard.
# Example: /data/whisper-debug
WHISPER_SERVER_DEBUG_DUMP_DIR=


# =========================
# Service: mpeg-v bot
# =========================
#
# These belong in the Discord bot service, not in the translate frontend
# and not in gowhisper.
#
# See also:
# /home/crunchy/dev/Obiente/mpeg-v/apps/bot/.env.example

# CLIENT_TOKEN=
# STREAM=http://serve:3000
# API_TOKEN=
# WHISPER_WS=wss://whisper.obiente.cloud/ws/transcribe
# TRANSLATE_PUBLIC_URL=https://translate.obiente.org
# VOICE_TRANSLATE_DEBUG_DUMP_DIR=/data/voice-debug


# =========================
# Service: mpeg-v serve
# =========================
#
# Required if you want the bot to resume voice translation sessions after
# restarts. This file must live on persistent storage.

# TRANSLATION_SESSIONS_FILE=/data/translation-sessions.json


# =========================
# Legacy / local-only notes
# =========================
#
# These are older frontend-local settings from the first Python attempt.
# Keep them only if you still use that path locally.

# WHISPER_MODEL_SIZE=large-v3
# WHISPER_BATCH_SIZE=4
# WHISPER_DEBUG_DIR=./.whisper-debug
